# === RestaurApp — variables de entorno ===
# Copiar a .env y completar. MONGODB_URI y JWT_SECRET son obligatorias.

# --- Núcleo ---
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/restaurapp
JWT_SECRET=cambiame-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES=7d
APP_BASE_URL=http://localhost:3000

# --- Mercado Pago (fallback global; por tenant se usa tokenRef) ---
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# --- WhatsApp Cloud API (Meta) ---
WA_VERIFY_TOKEN=
WA_APP_SECRET=

# --- Claude API (OCR de facturas, forecast, categorización) ---
ANTHROPIC_API_KEY=

# --- PedidosYa (Delivery Hero Plugin API) ---
PEYA_CLIENT_ID=
PEYA_CLIENT_SECRET=

# --- Worker ---
# Intervalo de polling de la cola de jobs en ms (worker async de webhooks)
WORKER_POLL_MS=2000

# --- Admin ---
# ¿Se aceptan registros de comercios nuevos? Poné "false" para cerrar el alta.
REGISTRATION_OPEN=true
